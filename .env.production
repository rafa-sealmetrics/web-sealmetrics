# Variables de entorno para `npm run build` en producción (GitHub Pages).
# Solo NEXT_PUBLIC_* — todo lo que va aquí queda inlineado en el bundle JS,
# así que no pongas secrets jamás. El Turnstile site key es público por
# diseño (el server-side secret vive en sealforce).

NEXT_PUBLIC_PIXEL_AUDITOR_API=https://pixel-auditor.sealmetrics.net
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADXJLn6VdfvKSO8v
